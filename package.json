{
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint && stylelint '**/*.css'",
    "lint:fix": "oxlint --fix; stylelint '**/*.css' --fix",
    "test": "bun test && playwright test",
    "test:coverage": "bun test --coverage && playwright test",
    "test:unit": "bun test",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "monocart-reporter": "^2.10.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "bun": ">=1.3.11"
  }
}
